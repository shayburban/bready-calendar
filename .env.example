VITE_BASE44_APP_ID=68959b55e8df62b2777a4530

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Google Calendar sync (SERVER-ONLY — never prefix these with VITE_) --------
# Used by the /api functions. Set in Vercel (Production + Preview), never shipped
# to the browser. See docs/google-calendar-sync-v1.md §12.

# Supabase service role key (bypasses RLS; google_account is server-only).
SUPABASE_SERVICE_ROLE_KEY=
# Optional: same as VITE_SUPABASE_URL; functions fall back to VITE_SUPABASE_URL.
SUPABASE_URL=

# Google OAuth client (GCP project bready---il). Add the calendar.events +
# calendar.freebusy scopes to the consent screen; redirect URI must match below.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://bready-calendar.vercel.app/api/google/oauth-callback

# 32-byte key, base64. Generate: openssl rand -base64 32
# Encrypts stored OAuth tokens AND signs the OAuth `state`.
CALENDAR_TOKEN_ENC_KEY=

# Public base URL of the app — used for the watch-channel webhook address and the
# post-OAuth redirect. e.g. https://bready-calendar.vercel.app
APP_BASE_URL=https://bready-calendar.vercel.app

# Bearer secret Vercel cron sends; the cron endpoints reject anything else.
CRON_SECRET=

# Optional: freebusy cache TTL in seconds (default 300).
FREEBUSY_THROTTLE_SECONDS=300

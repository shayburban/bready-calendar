{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r *)",
      "Bash(rm -rf:*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean --force*)",
      "Bash(git checkout -- *)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git branch -D *)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(chmod -R *)",
      "Bash(chown -R *)",
      "Bash(*DROP TABLE*)",
      "Bash(*TRUNCATE *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.tfvars)",
      "Read(secrets/**)",
      "Read(**/credentials*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-paths.mjs\"" }
        ]
      }
    ]
  }
}
